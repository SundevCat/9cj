// 9CJ Corp — Personal AI Operating System
// Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  direction     String   // LONG | SHORT
  entry         Float
  exit          Float?
  size          Float    // contracts (1 contract = 100 oz on Capital GOLD CFD)
  pnl           Float?
  status        String   @default("OPEN")  // OPEN | CLOSED | CANCELLED
  notes         String?
  // Live broker fields (broker-agnostic; currently Capital.com).
  // @map preserves the existing OANDA-named columns so historical rows keep their values.
  brokerDealId  String?  @map("oandaTradeId")  // Capital dealId; old OANDA tradeId values preserved
  brokerOrderId String?  @map("oandaOrderId")  // Capital dealReference; old OANDA orderId values preserved
  fillPrice     Float?   // actual fill price from broker
  isLive        Boolean  @default(false)       // false = journal only, true = real live trade
  instrument    String   @default("XAU_USD")
  stopLoss      Float?
  takeProfit    Float?

  @@index([createdAt])
  @@index([status])
}

model Memory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  agent     String
  tag       String   // TRADE | POLICY | AI | SYS | OK
  message   String
  metadata  Json?    // native JSON (PostgreSQL)

  @@index([createdAt])
  @@index([tag])
}

model Policy {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  ruleType    String   // MAX_TRADE_SIZE | DAILY_LOSS | SPEND_LIMIT | etc
  threshold   Float
  enabled     Boolean  @default(true)
  violations  Int      @default(0)
}

model Task {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  title     String
  module    String
  priority  String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED | DONE
  metadata  Json?    // native JSON (PostgreSQL)

  @@index([status])
}

model Price {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  source    String   @default("gold-api") // gold-api | oanda

  @@index([timestamp])
}

model FinanceEntry {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  occurredOn DateTime @default(now())
  type       String   // INCOME | EXPENSE
  category   String
  amount     Float
  currency   String   @default("THB")
  notes      String?

  @@index([occurredOn])
  @@index([type, category])
}

model Budget {
  id       Int    @id @default(autoincrement())
  category String @unique
  monthly  Float
  currency String @default("THB")
}

model PortfolioHolding {
  id        Int      @id @default(autoincrement())
  asset     String   @unique // XAU | CASH | EQUITIES | CRYPTO | ...
  amount    Float            // amount in base currency
  currency  String   @default("THB")
  notes     String?
  updatedAt DateTime @updatedAt
}

model Service {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  url       String
  enabled   Boolean        @default(true)
  createdAt DateTime       @default(now())
  checks    ServiceCheck[]
}

model ServiceCheck {
  id        Int      @id @default(autoincrement())
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ts        DateTime @default(now())
  ok        Boolean
  status    Int?
  latencyMs Int?
  error     String?

  @@index([serviceId, ts])
}

model DeployLog {
  id      Int      @id @default(autoincrement())
  ts      DateTime @default(now())
  service String
  version String?
  status  String   @default("OK") // OK | FAIL | ROLLBACK
  notes   String?

  @@index([ts])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KanbanCard {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  description String?
  status      String   @default("BACKLOG") // BACKLOG | IN_PROGRESS | REVIEW | DONE
  priority    String   @default("MEDIUM")  // HIGH | MEDIUM | LOW
  moduleTag   String?
  dueDate     DateTime?
  position    Int      @default(0)

  @@index([status, position])
}

model Violation {
  id        Int      @id @default(autoincrement())
  ts        DateTime @default(now())
  policyId  Int
  module    String
  action    String
  context   Json     // native JSON (PostgreSQL)
  severity  String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  resolved  Boolean  @default(false)
  taskId    Int?

  @@index([ts])
  @@index([resolved])
}

// Broker account snapshot — cached to avoid excessive API calls
model BrokerSnapshot {
  id             Int      @id @default(autoincrement())
  fetchedAt      DateTime @default(now())
  broker         String   @default("capital") // origin broker (capital | none)
  accountId      String
  balance        Float
  unrealizedPL   Float
  realizedPL     Float
  marginUsed     Float
  openTradeCount Int
  raw            Json     // full account JSON from the broker

  // @@map keeps the existing Postgres table so we don't lose snapshots.
  // Table can be renamed in a cleanup migration later.
  @@map("OandaSnapshot")
  @@index([fetchedAt])
}
