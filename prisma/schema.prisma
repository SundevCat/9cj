// 9CJ Corp — Personal AI Operating System
// Prisma schema (MongoDB)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Trade {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime @default(now())
  direction     String   // LONG | SHORT
  entry         Float
  exit          Float?
  size          Float
  pnl           Float?
  status        String   @default("OPEN")
  notes         String?
  brokerDealId  String?
  brokerOrderId String?
  fillPrice     Float?
  isLive        Boolean  @default(false)
  instrument    String   @default("XAU_USD")
  stopLoss      Float?
  takeProfit    Float?

  @@index([createdAt])
  @@index([status])
}

model Memory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  agent     String
  tag       String
  message   String
  metadata  Json?

  @@index([createdAt])
  @@index([tag])
}

model Policy {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  ruleType    String
  threshold   Float
  enabled     Boolean  @default(true)
  violations  Int      @default(0)
}

model Task {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  title     String
  module    String
  priority  String   @default("MEDIUM")
  status    String   @default("PENDING")
  metadata  Json?

  @@index([status])
}

model Price {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  timestamp DateTime @default(now())
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  source    String   @default("gold-api")

  @@index([timestamp])
}

model Setting {
  key       String   @id @map("_id")
  value     String
  updatedAt DateTime @updatedAt
}

model Violation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ts        DateTime @default(now())
  policyId  String   @db.ObjectId
  module    String
  action    String
  context   Json
  severity  String   @default("MEDIUM")
  resolved  Boolean  @default(false)
  taskId    String?  @db.ObjectId

  @@index([ts])
  @@index([resolved])
}

model BrokerSnapshot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  fetchedAt      DateTime @default(now())
  broker         String   @default("capital")
  accountId      String
  balance        Float
  unrealizedPL   Float
  realizedPL     Float
  marginUsed     Float
  openTradeCount Int
  raw            Json

  @@index([fetchedAt])
}
