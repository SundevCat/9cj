// 9CJ Corp — Personal AI Operating System
// Prisma schema (SQLite — single file at prisma/dev.db)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trade {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  direction     String   // LONG | SHORT
  entry         Float
  exit          Float?
  size          Float    // contracts (1 contract = 100 oz on Capital GOLD CFD)
  pnl           Float?
  status        String   @default("OPEN")  // OPEN | CLOSED | CANCELLED
  notes         String?
  brokerDealId  String?  // Capital dealId (persistent position id)
  brokerOrderId String?  // Capital dealReference
  fillPrice     Float?
  isLive        Boolean  @default(false)
  instrument    String   @default("XAU_USD")
  stopLoss      Float?
  takeProfit    Float?

  @@index([createdAt])
  @@index([status])
}

model Memory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  agent     String
  tag       String   // TRADE | POLICY | AI | SYS | OK | WARN | ERR
  message   String
  metadata  String?  // JSON-encoded; SQLite has no native JSON

  @@index([createdAt])
  @@index([tag])
}

model Policy {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  ruleType    String   // MAX_TRADE_SIZE | DAILY_LOSS | etc
  threshold   Float
  enabled     Boolean  @default(true)
  violations  Int      @default(0)
}

model Task {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  title     String
  module    String
  priority  String   @default("MEDIUM")
  status    String   @default("PENDING")
  metadata  String?  // JSON-encoded

  @@index([status])
}

model Price {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?
  source    String   @default("gold-api")

  @@index([timestamp])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Violation {
  id        Int      @id @default(autoincrement())
  ts        DateTime @default(now())
  policyId  Int
  module    String
  action    String
  context   String   // JSON-encoded
  severity  String   @default("MEDIUM")
  resolved  Boolean  @default(false)
  taskId    Int?

  @@index([ts])
  @@index([resolved])
}

model BrokerSnapshot {
  id             Int      @id @default(autoincrement())
  fetchedAt      DateTime @default(now())
  broker         String   @default("capital")
  accountId      String
  balance        Float
  unrealizedPL   Float
  realizedPL     Float
  marginUsed     Float
  openTradeCount Int
  raw            String   // JSON-encoded

  @@index([fetchedAt])
}
