# Bangkok timezone
TZ=Asia/Bangkok

# ─── Live trading broker ──────────────────────────────────────────────────────
# Capital.com is the only supported broker.
# Set BROKER=none to disable live trading.
# Leave BROKER unset to auto-detect from CAPITAL_* creds.
